# Copy to .env.local and fill in values — never commit .env.local

# API base URL — in dev, Vite proxies /api/* to the backend services.
# In production, set to the full API gateway URL.
VITE_API_BASE_URL=http://localhost:3000/api 

# App metadata
VITE_APP_NAME=Atlas IaaS
VITE_APP_VERSION=0.1.0

# Feature flags
VITE_ENABLE_DEVTOOLS=true
